# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
Untitled-1.txt

# Figma import pipeline — per-run generated artifacts (R2 URLs, intermediate
# HTML/CSS, standalone preview). Safe to regenerate from source.jsx + R2.
/scripts/figma-import-*/artifacts/
/node_modules/.cache/iwo-figma-tw/
