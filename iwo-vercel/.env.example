# ──────────────────────────────────────────────────────────────────────────────
# iwo-watch / iwo-vercel — environment variables template
# Copy to `.env.local` and fill in real values. DO NOT commit real secrets.
# ──────────────────────────────────────────────────────────────────────────────

# ── Admin JWT (Fix 1) ────────────────────────────────────────────────────────
# HS256 signing secret for admin tokens. Min 32 chars. Generate with e.g.
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ADMIN_JWT_SECRET=""

# Bcrypt hash of the admin password. Generate with:
#   node -e "console.log(require('bcryptjs').hashSync(process.argv[1], 12))" 'your-password'
# If ADMIN_PASSWORD_HASH is set, ADMIN_PASSWORD is ignored.
ADMIN_PASSWORD_HASH=""

# DEPRECATED: plaintext admin password. Only used if ADMIN_PASSWORD_HASH is empty.
# Migrate to ADMIN_PASSWORD_HASH as soon as possible.
ADMIN_PASSWORD=""

# ── MercadoPago (Fix 3) ──────────────────────────────────────────────────────
# MP access token (server-side only).
MP_ACCESS_TOKEN=""

# MP webhook secret — used to HMAC-verify signed notifications.
# Obtain from MercadoPago dashboard → Your integrations → Webhooks → Secret.
# REQUIRED: if missing, the webhook endpoint returns 503 (fail-closed).
MP_WEBHOOK_SECRET=""

# ── Postgres (Vercel Postgres) ───────────────────────────────────────────────
POSTGRES_URL=""
POSTGRES_PRISMA_URL=""
POSTGRES_URL_NON_POOLING=""

# ── R2 / S3 uploads ──────────────────────────────────────────────────────────
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# ── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://iwowatch.com.br"

# ── NextAuth v5 (customer auth) ──────────────────────────────────────────────
# HS256/JWT signing secret for NextAuth sessions. Min 32 chars. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
NEXTAUTH_SECRET=""
NEXTAUTH_URL="http://localhost:3000"
AUTH_TRUST_HOST="true"

# ── Transactional email (Resend) ─────────────────────────────────────────────
# API key from https://resend.com/api-keys. Leave empty in local dev to log
# messages to stdout instead of sending them.
RESEND_API_KEY=""

# Verified "From" address. Include display name if desired.
RESEND_FROM_EMAIL="IWO Watch <no-reply@iwowatch.com.br>"

# ── SuperFrete ───────────────────────────────────────────────────────────────
# Base URL do ambiente (sandbox ou produção).
SUPERFRETE_API_URL="https://sandbox.superfrete.com"

# Token de autenticação SuperFrete (Bearer). Fornecido pelo painel da SuperFrete.
# NOTE: nome da var usa "SUPERFRET" (escolha do usuário, sem E final).
SUPERFRET_APITOKEN=""

# User-Agent exigido pela SuperFrete: "Nome da aplicação (email de contato técnico)".
SUPERFRETE_USER_AGENT="IWO Watch (gsbcommerceltda@gmail.com)"

# ── Remetente (loja) ─────────────────────────────────────────────────────────
SHIPPING_FROM_NAME="IWO Watch Brasil"
SHIPPING_FROM_DOCUMENT="46601604000194"
SHIPPING_FROM_POSTAL_CODE="13026137"
SHIPPING_FROM_ADDRESS="Av Princesa Doeste"
SHIPPING_FROM_NUMBER="1199"
SHIPPING_FROM_COMPLEMENT="Sala 92"
SHIPPING_FROM_DISTRICT="NA"
SHIPPING_FROM_CITY="Campinas"
SHIPPING_FROM_STATE="SP"
