# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# -------- Secrets --------
# Env files — NEVER commit, even locally. Allowlist example templates.
.env
.env.*
!.env.example
!.env.sample

# API keys, service accounts, credentials (standard patterns)
*service-account*.json
*-credentials.json
*.key
*.pem
winter-ace-*.json

# -------- Editor / IDE / OS --------
.vscode/
.idea/
.history/
.DS_Store
Thumbs.db
*.swp

# -------- Dependencies --------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# -------- Build / generated --------
/.next/
/out/
/build
/coverage
*.tsbuildinfo
next-env.d.ts

# -------- Deploy --------
.vercel

# -------- Logs --------
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# -------- Claude Code / ruflo / agent caches --------
.claude/
.claude-flow/
.agents/
.claude-trajectories/
